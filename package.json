{
  "name": "multi-explorer-webapp-site-publish",
  "private": true,
  "type": "module",
  "scripts": {
    "build:pages": "node scripts/build-pages-output.mjs",
    "build:combine": "node scripts/build-combine-bundle.mjs",
    "build:d1-bart-splits": "python scripts/build-d1-bart-splits.py",
    "build:d1-hoop-rapm": "python scripts/update_d1_hoop_rapm.py",
